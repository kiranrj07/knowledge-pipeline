# External service credentials
# Copy this file to .env and fill in the values. .env is gitignored.
GITHUB_TOKEN=
OPENROUTER_API_KEY=

# Parallel.ai discovery. Two modes:
#   1. SDK (recommended): set PARALLEL_API_KEY and the orchestrator uses the
#      parallel-web Python SDK (richer free tier, better relevance).
#   2. MCP fallback: if no API key, the orchestrator falls back to the no-auth
#      MCP endpoint. Works for general queries but tends to return 0 results
#      for deep technical topics.
# Get a free key at https://platform.parallel.ai
PARALLEL_API_KEY=
PARALLEL_MCP_URL=https://search.parallel.ai/mcp

# Local services
# QDRANT_PATH uses Qdrant local-mode (no Docker daemon required).
QDRANT_PATH=./qdrant_storage
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM choices
RESEARCH_LLM=qwen3:14b
# OpenRouter model id for escalation review. See https://openrouter.ai/models
REVIEW_LLM=openrouter/anthropic/claude-sonnet-4-20250514

# Tunables
MAX_DISCOVERY_URLS=12
MAX_GITHUB_FILES=8
CHUNK_SIZE_CHARS=1500
CHUNK_OVERLAP_CHARS=200
